---
interface Props {
	badge?: {
		text: string;
		href?: string;
	};
}

const { hero } = Astro.locals.starlightRoute.entry.data;
// biome-ignore lint/correctness/noUnusedVariables: used in template below frontmatter
const { tagline, actions } = hero || {};
// biome-ignore lint/correctness/noUnusedVariables: used in template below frontmatter
const { badge } = Astro.props;
---

{tagline && (
  <div class="hero-wrapper">
    <div class="hero-blur-1"></div>
    <div class="hero-blur-2"></div>
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-content">
      {badge && (
        <a
          href={badge.href || "#"}
          class="hero-badge"
        >
          <svg class="hero-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
          <span class="hero-badge-text">{badge.text}</span>
          <svg class="hero-badge-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      )}
      <img src="/Payfast-logo.svg" alt="PayFast" class="hero-logo" />
      <h1 class="hero-tagline">{tagline}</h1>
      {actions && actions.length > 0 && (
        <div class="hero-actions">
          {actions.map((action) => (
            <a
              href={action.link}
              class={`hero-action ${action.variant === "primary" ? "hero-action--primary" : "hero-action--secondary"}`}
              {...(action.attrs || {})}
            >
              <span class="hero-action-text">{action.text}</span>
              {action.icon && (
                <svg class="hero-action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  {action.icon === "right-arrow" && (
                    <path d="M5 12h14M12 5l7 7-7 7" />
                  )}
                  {action.icon === "external" && (
                    <>
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </>
                  )}
                </svg>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
)}

<style is:global>
  .hero-wrapper {
    position: relative;
    overflow: hidden;
    padding: 4rem 1rem 3rem;
    text-align: center;
  }

  .hero-blur-1 {
    position: absolute;
    top: -120px;
    right: -120px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(97, 175, 239, 0.06) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-blur-2 {
    position: absolute;
    bottom: -80px;
    left: -80px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(198, 120, 221, 0.04) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(97, 175, 239, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(97, 175, 239, 0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black 20%, transparent 70%);
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 400px;
    height: 400px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(97, 175, 239, 0.08) 0%, transparent 70%);
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    animation: fadeInUp 0.6s ease-out both;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 100px;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: all 0.2s ease;
  }

  .hero-badge:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }

  .hero-badge-icon {
    width: 14px;
    height: 14px;
    color: var(--sl-color-accent);
  }

  .hero-badge-arrow {
    width: 12px;
    height: 12px;
  }

  .hero-logo {
    height: 44px;
    width: auto;
    margin: 0 auto 1rem;
    display: block;
  }

  .hero-tagline {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--sl-color-white);
    margin: 0 auto 1.5rem;
    max-width: 720px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease-out 0.15s both;
  }

  .hero-action {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .hero-action--primary {
    background: var(--sl-color-accent);
    color: #fff;
    box-shadow: 0 0 0 0 rgba(97, 175, 239, 0.4);
  }

  .hero-action--primary:hover {
    background: #528bff;
    box-shadow: 0 0 24px rgba(97, 175, 239, 0.3);
    transform: translateY(-1px);
  }

  .hero-action--secondary {
    border: 1px solid var(--sl-color-gray-4);
    color: var(--sl-color-gray-2);
  }

  .hero-action--secondary:hover {
    border-color: var(--sl-color-gray-3);
    color: var(--sl-color-white);
    background: var(--sl-color-gray-5);
  }

  .hero-action-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 50em) {
    .hero-wrapper {
      padding: 6rem 1rem 4rem;
    }
  }
</style>
