---
interface Card {
  title: string;
  href: string;
  icon: string;
  description: string;
  accent: "blue" | "green" | "purple" | "orange" | "red";
}

interface Props {
  cards: Card[];
}

const { cards } = Astro.props;

const accentColors: Record<Card["accent"], { bg: string; iconBg: string; border: string }> = {
  blue: {
    bg: "var(--bento-blue-bg)",
    iconBg: "var(--bento-blue-icon)",
    border: "var(--bento-blue-border)",
  },
  green: {
    bg: "var(--bento-green-bg)",
    iconBg: "var(--bento-green-icon)",
    border: "var(--bento-green-border)",
  },
  purple: {
    bg: "var(--bento-purple-bg)",
    iconBg: "var(--bento-purple-icon)",
    border: "var(--bento-purple-border)",
  },
  orange: {
    bg: "var(--bento-orange-bg)",
    iconBg: "var(--bento-orange-icon)",
    border: "var(--bento-orange-border)",
  },
  red: {
    bg: "var(--bento-red-bg)",
    iconBg: "var(--bento-red-icon)",
    border: "var(--bento-red-border)",
  },
};
---

<div class="bento-grid">
  {
    cards.map((card) => {
      const colors = accentColors[card.accent];
      return (
        <a
          href={card.href}
          class="bento-card"
          style={`--card-bg: ${colors.bg}; --card-icon-bg: ${colors.iconBg}; --card-border: ${colors.border};`}
        >
          <div class="bento-card-icon">
            <span>{card.icon}</span>
          </div>
          <div class="bento-card-body">
            <h3 class="bento-card-title">{card.title}</h3>
            <p class="bento-card-desc">{card.description}</p>
          </div>
          <svg class="bento-card-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      );
    })
  }
</div>

<style is:global>
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 2rem 0;
  }

  @media (min-width: 50em) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .bento-card {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 12px;
    border: 1px solid var(--card-border, var(--sl-color-gray-5));
    background: var(--card-bg, var(--sl-color-gray-6));
    text-decoration: none;
    transition: all 0.25s ease;
    overflow: hidden;
  }

  .bento-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 12px;
    opacity: 0;
    transition: opacity 0.25s ease;
    box-shadow: 0 0 24px var(--card-border, transparent);
  }

  .bento-card:hover {
    border-color: var(--card-border, var(--sl-color-accent));
    transform: translateY(-2px);
  }

  .bento-card:hover::before {
    opacity: 0.3;
  }

  .bento-card-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    background: var(--card-icon-bg, var(--sl-color-gray-5));
  }

  .bento-card-body {
    flex: 1;
    min-width: 0;
  }

  .bento-card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--sl-color-white);
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }

  .bento-card-desc {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
    margin: 0;
    line-height: 1.4;
  }

  .bento-card-arrow {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    color: var(--sl-color-gray-3);
    margin-top: 0.25rem;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .bento-card:hover .bento-card-arrow {
    transform: translateX(3px);
    color: var(--sl-color-accent);
  }
</style>
