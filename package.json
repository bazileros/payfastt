{
	"name": "payfastt",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^6",
			"next-themes": "^0.4.6",
			"react": "^19.2.6",
			"react-dom": "^19.2.6",
			"convex": "^1.33.1",
			"@types/react": "^19.2.15",
			"@types/react-dom": "^19.2.3",
			"alchemy": "^0.91.2"
		}
	},
	"type": "module",
	"scripts": {
		"bootstrap": "cd packages/payfast && bun run build:codegen && cd ../.. && turbo -F @payfastt/backend dev:setup",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F @payfastt/backend dev",
		"dev:setup": "turbo -F @payfastt/backend dev:setup",
		"deploy": "turbo -F @payfastt/infra deploy",
		"destroy": "turbo -F @payfastt/infra destroy",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@payfastt/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@payfastt/config": "workspace:*",
		"turbo": "^2.9.16",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.11"
}
